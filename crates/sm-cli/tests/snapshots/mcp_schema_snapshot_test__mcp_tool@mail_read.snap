    "additionalProperties": false,
    "properties": {
      "peek": {
        "description": "Return unread mail without marking it read.",
        "type": "boolean"
      },
      "selector": {
        "description": "Inbox owner selector.",
        "type": "string"
      }
    },
    "required": [
      "selector"
    ],
    "type": "object"
  },
  "name": "mail_read",
  "outputSchema": {
    "properties": {
      "errors": {
        "items": {
          "type": "object"
        },
        "type": "array"
      },
      "mail": {
        "items": {
          "type": "object"
        },
        "type": "array"
      }
    },
    "required": [
      "mail"
    ],
    "type": "object"
  }
}
