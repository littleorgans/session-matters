---
source: crates/sm-cli/tests/mcp_schema_snapshot_test.rs
expression: tool
---
{
  "description": "Capture tmux pane scrollback for one selected session.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "all_namespaces": {
        "description": "Bypass namespace scoping and read across all namespaces.",
        "type": "boolean"
      },
      "namespace": {
        "description": "Namespace slug to scope this read. Overrides the caller session namespace fallback.",
        "type": "string"
      },
      "scrollback_lines": {
        "description": "Maximum tmux scrollback lines to include.",
        "type": "integer"
      },
      "selector": {
        "description": "Session selector to capture. Usually id:<uuid>.",
        "type": "string"
      }
    },
    "required": [
      "selector"
    ],
    "type": "object"
  },
  "name": "session_capture",
  "outputSchema": {
    "properties": {
      "capture": {
        "properties": {
          "payload": {
            "type": "object"
          },
          "status": {
            "enum": [
              "captured",
              "failed"
            ],
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "type": "object"
      },
      "session": {
        "type": "object"
      }
    },
    "required": [
      "session",
      "capture"
    ],
    "type": "object"
  }
}
