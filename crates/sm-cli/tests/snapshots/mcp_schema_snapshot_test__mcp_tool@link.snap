{
  "description": "Attach runtime metadata to one unmanaged session. Daemon-spawned headless sessions link stdout logs automatically.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "runtime_session": {
        "description": "Runtime session id reported by the SessionStart hook.",
        "type": "string"
      },
      "selector": {
        "description": "Selector that must match exactly one session when session_id is omitted.",
        "type": "string"
      },
      "session_id": {
        "description": "Session id to link. CLI defaults to HELIOY_SESSION_ID when omitted.",
        "type": "string"
      },
      "transcript": {
        "description": "Transcript path reported by the SessionStart hook.",
        "type": "string"
      }
    },
    "required": [
      "runtime_session",
      "transcript"
    ],
    "type": "object"
  },
  "name": "link",
  "outputSchema": {
    "properties": {
      "session": {
        "type": "object"
      }
    },
    "required": [
      "session"
    ],
    "type": "object"
  }
}
