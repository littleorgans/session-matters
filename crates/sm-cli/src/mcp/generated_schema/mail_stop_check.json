{
  "description": "Return the unread mail count for stop-hook decisions without draining mail.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "selector": {
        "description": "Inbox owner selector.",
        "type": "string"
      }
    },
    "required": [
      "selector"
    ],
    "type": "object"
  },
  "name": "mail_stop_check",
  "outputSchema": {
    "properties": {
      "counts": {
        "items": {
          "type": "object"
        },
        "type": "array"
      },
      "unread": {
        "type": "integer"
      }
    },
    "required": [
      "unread"
    ],
    "type": "object"
  }
}
