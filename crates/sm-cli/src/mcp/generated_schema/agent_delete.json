{
  "description": "Terminate one daemon owned agent runtime by id and return the updated session record. Defaults to SIGTERM with a five second grace period.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "grace_secs": {
        "description": "Seconds to wait before SIGKILL. Defaults to 5.",
        "type": "integer"
      },
      "id": {
        "description": "Session id to terminate.",
        "type": "string"
      },
      "signal": {
        "description": "Signal to send. Defaults to SIGTERM.",
        "type": "string"
      }
    },
    "required": [
      "id"
    ],
    "type": "object"
  },
  "name": "agent_delete",
  "outputSchema": {
    "properties": {
      "session": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "exit_code": {
            "type": [
              "integer",
              "null"
            ]
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "runtime": {
            "enum": [
              "claude",
              "codex"
            ],
            "type": "string"
          },
          "runtime_pid": {
            "type": "integer"
          },
          "started_at": {
            "format": "date-time",
            "type": "string"
          },
          "state": {
            "enum": [
              "SPAWNING",
              "RUNNING",
              "TERMINATED"
            ],
            "type": "string"
          },
          "terminated_at": {
            "format": "date-time",
            "type": [
              "string",
              "null"
            ]
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          },
          "workspace": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "runtime",
          "role",
          "workspace",
          "state",
          "runtime_pid",
          "created_at",
          "started_at",
          "terminated_at",
          "updated_at"
        ],
        "type": "object"
      }
    },
    "required": [
      "session"
    ],
    "type": "object"
  }
}
