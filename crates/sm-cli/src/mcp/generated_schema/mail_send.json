{
  "description": "Send durable mail to one session id. Selector addressing lands in a later pass.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "content": {
        "description": "Message content.",
        "type": "string"
      },
      "from": {
        "description": "Sender session id. Defaults to HELIOY_SESSION_ID when set; otherwise smd records the controller sender.",
        "type": "string"
      },
      "to": {
        "description": "Recipient session id.",
        "type": "string"
      }
    },
    "required": [
      "to",
      "content"
    ],
    "type": "object"
  },
  "name": "mail_send",
  "outputSchema": {
    "properties": {
      "mail": {
        "properties": {
          "content": {
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "read_at": {
            "format": "date-time",
            "type": [
              "string",
              "null"
            ]
          },
          "recipient_id": {
            "format": "uuid",
            "type": "string"
          },
          "sender_id": {
            "format": "uuid",
            "type": "string"
          },
          "sent_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "sender_id",
          "recipient_id",
          "content",
          "sent_at"
        ],
        "type": "object"
      }
    },
    "required": [
      "mail"
    ],
    "type": "object"
  }
}
